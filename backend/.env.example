PORT=4000
# Local: mongodb://127.0.0.1:27017/buddy-script
# Atlas: mongodb+srv://<user>:<password>@<cluster>/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/buddy-script

# Same value must be set in frontend/.env.local for route protection (middleware)
JWT_SECRET=change-this-to-a-long-random-string-at-least-16-chars
# Optional: session length in seconds (default 604800 = 7 days)
# JWT_EXPIRES_SEC=604800

# CORS: browser origin(s) allowed to call the API with credentials. Comma-separate for multiple (e.g. preview + prod).
FRONTEND_ORIGIN=http://localhost:3000

# Behind nginx/Render/etc.: set so rate limits and logs see the real client IP (X-Forwarded-For).
# TRUST_PROXY=true
